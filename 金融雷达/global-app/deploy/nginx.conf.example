# Nginx 反向代理 + HTTPS 模板
# 放到 /etc/nginx/conf.d/finance-radar.conf，把 your-domain.com 换成你的域名
# HTTPS 证书用 certbot 自动申请（见 DEPLOY.md）

# HTTP：全部跳转到 HTTPS
server {
    listen 80;
    server_name your-domain.com;
    location / { return 301 https://$host$request_uri; }
}

server {
    listen 443 ssl http2;
    server_name your-domain.com;

    # certbot 会自动填这两行（申请证书后）
    ssl_certificate     /etc/letsencrypt/live/your-domain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-domain.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    # 反向代理到 Node 服务
    location / {
        proxy_pass http://127.0.0.1:8288;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        # 关键：把真实访客 IP 透传给 Node（限流/统计按真实 IP）
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 60s;
    }

    # 管理后台可选：限制只有你自己的 IP 能访问（去掉注释并改成你的公网 IP）
    # location /admin.html { allow 1.2.3.4; deny all; proxy_pass http://127.0.0.1:8288; }

    gzip on;
    gzip_types text/css application/javascript application/json image/svg+xml;
}
